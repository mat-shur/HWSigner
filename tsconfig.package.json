{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": false
  },
  "include": ["src/index.ts", "src/core.ts", "src/react-native.ts", "src/lib/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/app/**", "src/components/**", "src/data/**"]
}
